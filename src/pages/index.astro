---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHOR_NAME, GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.profile {
				padding: 2em 0;
				text-align: center;
			}
			.profile h1 {
				margin-bottom: 0.25em;
			}
			.profile .handle {
				color: rgb(var(--gray));
				font-size: 1.1em;
			}
			.profile .role {
				margin: 1em 0 0.5em;
				font-weight: 700;
			}
			.profile .bio {
				max-width: 36em;
				margin: 0 auto;
			}
			.profile .links {
				margin-top: 1.5em;
			}
			.recent-posts {
				margin-top: 3em;
			}
			.recent-posts ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.recent-posts li {
				display: flex;
				gap: 1em;
				align-items: baseline;
				padding: 0.5em 0;
			}
			.recent-posts .date {
				flex-shrink: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.recent-posts a {
				text-decoration: none;
			}
			.more {
				margin-top: 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="profile">
				<h1>{AUTHOR_NAME}</h1>
				<p class="handle">@seckie</p>
				<p class="role">Engineering Manager @ SaaS company</p>
				<p class="bio">
					SaaS運営企業でエンジニアリングマネージャーをしています。元フロントエンドエンジニア。
					このサイトでは、エンジニアリングマネジメントやソフトウェア開発について書いていきます。
				</p>
				<p class="links">
					<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
				</p>
			</section>
			<section class="recent-posts">
				<h2>最近の記事</h2>
				<ul>
					{
						recentPosts.map((post) => (
							<li>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</li>
						))
					}
				</ul>
				<p class="more"><a href="/blog/">記事一覧へ →</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>
